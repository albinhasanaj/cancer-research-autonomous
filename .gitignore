# Secrets / environment
.env

# Python
__pycache__/
*.pyc
*.pyo

# Vector store (rebuilt from research/ via reindex())
memory/.chroma/

# Bulk data artifacts (keep the folder via .gitkeep)
data/*
!data/.gitkeep

# Scratch exec
scratch/_exec.py
scratch/_smoke.py

# Stale pre-refactor duplicates that reappear in this shared environment.
# The canonical raw-API loop lives in api_backend/. Never re-track these.
/AGENT.md
/agents/
/agentic_loops/
/tools/file_tools.py
/tools/exec_tools.py

# Loop runtime state (human-in-the-loop escalation)
.notified
.all-blocked
NEEDS_HUMAN.log

code-reference/