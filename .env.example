# Copy to .env and fill in. The scaffold runs many functions without keys,
# but the LLM loop requires a provider key.

# Anthropic (default provider)
ANTHROPIC_API_KEY=

# OpenAI (alternative provider)
OPENAI_API_KEY=

# NCBI E-utilities key (optional; raises PubMed rate limit). Works without it.
NCBI_API_KEY=

XAI_API_KEY=
