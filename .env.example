# Copy to .env and fill in. The scaffold runs many functions without keys; the
# Copilot loop is the brain (no provider key needed for it), but tools/scripts
# that call an LLM use one of the provider keys below.

# OpenAI (OPENAI_API_KEY) — base_url https://api.openai.com/v1
OPENAI_API_KEY=

# xAI Grok (XAI_API_KEY) — base_url https://api.x.ai/v1 (OpenAI-SDK compatible)
XAI_API_KEY=

# NCBI E-utilities key (optional; raises PubMed rate limit). Works without it.
NCBI_API_KEY=
